    "version": "0.2.0",
    "configurations": [
        {
            "name": "C#: Debug",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/EasyValidate/EasyValidate.csproj"
        },
        {
            "name": "C#: Debug Console",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/EasyValidate.ConsoleTest/EasyValidate.ConsoleTest.csproj"
        },
        {
            "name": "Attach to Source Generator",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}